{
  "mcpServers": {
    "awslabs.aws-iac-mcp-server": {
      "type": "stdio",
      "command": "uv",
      "args": ["run", "awslabs.aws-iac-mcp-server"],
      "env": {
        "AWS_PROFILE": "master",
        "FASTMCP_LOG_LEVEL": "ERROR"
      }
    },
    "nixos": {
      "type": "stdio",
      "command": "uv",
      "args": ["run", "mcp-nixos"],
      "env": {}
    },
    "textlint": {
      "type": "stdio",
      "command": "vp",
      "args": ["exec", "textlint", "--mcp"],
      "env": {}
    }
  }
}
