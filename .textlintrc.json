{
  "plugins": {},
  "filters": { "comments": true },
  "rules": {
    "preset-ja-spacing": { "ja-space-between-half-and-full-width": { "space": "always" } },
    "preset-ja-technical-writing": {
      "no-mix-dearu-desumasu": {
        "preferInHeader": "である",
        "preferInBody": "である",
        "preferInList": "である"
      },
      "sentence-length": false
    },
    "prh": {
      "rulePaths": ["./node_modules/prh/prh-rules/media/techbooster.yml"]
    }
  }
}
