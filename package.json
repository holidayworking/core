{
  "name": "core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "run-p --aggregate-output --continue-on-error --print-label lint:*",
    "lint:markdownlint": "markdownlint-cli2",
    "lint:textlint": "textlint ./**/*.md",
    "fix": "run-s fix:*",
    "fix:markdownlint": "markdownlint-cli2 --fix",
    "fix:textlint": "textlint --fix ./**/*.md "
  },
  "devDependencies": {
    "markdownlint": "catalog:",
    "markdownlint-cli2": "catalog:",
    "npm-run-all2": "catalog:",
    "prh": "catalog:",
    "textlint": "catalog:",
    "textlint-filter-rule-comments": "catalog:",
    "textlint-rule-preset-ja-spacing": "catalog:",
    "textlint-rule-preset-ja-technical-writing": "catalog:",
    "textlint-rule-prh": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": "24.15.0"
  },
  "packageManager": "pnpm@10.33.2"
}
