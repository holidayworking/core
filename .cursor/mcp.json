{
  "mcpServers": {
    "aws-iac-mcp-server": {
      "command": "uv",
      "args": ["run", "awslabs.aws-iac-mcp-server"],
      "env": {
        "AWS_PROFILE": "master",
        "FASTMCP_LOG_LEVEL": "ERROR"
      }
    },
    "codex": {
      "command": "codex",
      "args": ["mcp-server"]
    },
    "nixos": {
      "command": "uv",
      "args": ["run", "mcp-nixos"]
    },
    "textlint": {
      "command": "vp",
      "args": ["exec", "textlint", "--mcp"],
      "env": {}
    }
  }
}
